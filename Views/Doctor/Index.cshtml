@model IEnumerable<El_Mooo_Clinic.DTOs.DtoDoctor.ReadDTO>

@{
    ViewData["Title"] = "Doctors Directory";
}

<style>
    .mooo-search-wrapper {
        background-color: #ffffff;
        border: 3px solid #1a1a1a;
        border-radius: 50px;
        padding: 6px 12px;
        box-shadow: 4px 4px 0px #1a1a1a;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
    }

        .mooo-search-wrapper:focus-within {
            transform: translateY(-2px);
            box-shadow: 6px 6px 0px #37bd74;
            border-color: #37bd74;
        }

    .mooo-search-input {
        border: none;
        background: transparent;
        font-size: 1.2rem;
        font-weight: 600;
        padding: 10px 15px;
        width: 100%;
        outline: none;
        color: #1a1a1a;
    }

        .mooo-search-input::placeholder {
            color: #adb5bd;
            font-weight: 500;
        }

    .mooo-clear-btn {
        background-color: #f8f9fa;
        color: #1a1a1a !important;
        border: 2px solid #1a1a1a;
        border-radius: 40px;
        padding: 8px 20px;
        font-weight: 800;
        text-decoration: none;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .mooo-clear-btn:hover {
            background-color: #e9ecef;
            transform: scale(1.05);
        }
</style>

<div class="container mt-5 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-4 border-dark pb-3">
        <h1 class="text-primary fw-bold display-5 mb-0" style="text-shadow: 2px 2px 0px #000;">
            👨‍⚕️ Doctors Directory
        </h1>
        <a href="/Doctor/Create" class="btn btn-success px-3 fw-semibold">
            + Add New Doctor
        </a>
    </div>

    <div class="row mb-5 justify-content-center">
        <div class="col-md-8">
            <div class="mooo-search-wrapper">
                <span class="fs-4 ms-2">🔍</span>

                <input type="text" id="doctorSearchInput" name="searchString" value="@ViewData["CurrentSearch"]"
                       class="mooo-search-input"
                       placeholder="Search by Name, Phone, or Department..."
                       autocomplete="off" />

                <a href="/Doctor" class="mooo-clear-btn d-flex align-items-center">
                    ✖ Clear
                </a>
            </div>
        </div>
    </div>

    <div id="doctorTable" class="card border-4 border-dark shadow-sm" style="box-shadow: 8px 8px 0px #000 !important;">
        @await Html.PartialAsync("_DoctorTablePartial", Model)
    </div>

</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            $('#doctorSearchInput').on('keyup', function () {
                var searchString = $(this).val();

                $.ajax({
                    url: '/Doctor/Index',
                    type: 'GET',
                    data: { searchString: searchString },
                    success: function (result) {
                        $('#doctorTable').html(result);
                    },
                    error: function (error) {
                        console.log("Error fetching data: ", error);
                    }
                });
            });

        });
    </script>
}