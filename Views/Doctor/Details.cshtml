@using El_Mooo_Clinic.Models
@model El_Mooo_Clinic.DTOs.DtoDoctor.ReadDTO

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <a href="/Doctor" class="btn btn-light btn-sm me-3">← Back</a>
        <h2 class="fw-bold m-0 text-primary">Doctor Profile</h2>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-2 border-dark text-center p-4 mb-4">
                @{
                    var defaultImage = Model.Gender == ClsEnums.Gender.Female
                    ? "/Images/DefaultImageDoctorFemale.jpg"
                    : "/Images/DefaultImageDoctorMale.jpg";
                }

                <img src="/images/doctors/@Model.ProfilePicture"
                     class="rounded-circle avatar mx-auto mb-3 border border-4 border-dark shadow-sm"
                     style="width: 150px; height: 150px; object-fit: cover; background-color: #f8f9fa;"
                     onerror="this.src='@defaultImage'" />

                <h3 class="fw-bold">@Model.Name</h3>
                <span class="badge bg-info text-dark border border-dark mb-3">@Model.DepartmentName</span>

                <div class="text-start mt-3">
                    <p class="mb-2">
                        <span class="fw-bold">🆔 ID:</span> #@Model.ID
                    </p>
                    <p class="mb-2">
                        <span class="fw-bold">📱 Phone:</span> @Model.PhoneNumber
                    </p>
                    <p class="mb-2">
                        <span class="fw-bold">🎂 Age:</span> @Model.Age
                    </p>
                    <p class="mb-2">
                        <span class="fw-bold">💰 Cost:</span> @Model.ExaminationCost EGP
                    </p>
                </div>

                <a href="/Doctor/Edit/@Model.ID" class="btn btn-primary w-100 mt-2">Edit Basic Info</a>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-2 border-dark mb-4">
                <div class="card-header bg-dark text-white fw-bold">📄 Personal & Professional Details</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 mb-2"><strong>Gender:</strong> @Model.GenderName</div>
                        <div class="col-6 mb-2"><strong>Age:</strong> @Model.Age Years</div>
                        <div class="col-6 mb-2"><strong>Birth Date:</strong> @Model.BirthDate.ToShortDateString()</div>
                        <div class="col-6 mb-2"><strong>Status:</strong> <span class="text-success">● Active</span></div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-2 border-dark border-primary">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span class="fw-bold">📅 Working Schedule</span>
                    <a href="/Doctor/ManageSchedule/@Model.ID" class="btn btn-sm btn-light border-dark fw-bold">Manage Schedule</a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Day</th>
                                <th>From</th>
                                <th>To</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Schedules != null && Model.Schedules.Any())
                            {
                                @foreach (var schedule in Model.Schedules.OrderBy(s => (int)Enum.Parse(typeof(DayOfWeek), s.DayName)))
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold">@schedule.DayName</td>
                                        <td>@DateTime.Today.Add(schedule.StartTime).ToString("hh:mm tt")</td>
                                        <td>@DateTime.Today.Add(schedule.EndTime).ToString("hh:mm tt")</td>
                                        <td class="text-center">
                                            <span class="badge bg-success border border-dark">Active</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted small italic">
                                        No schedule set yet. Click "Manage Schedule" to add working hours.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="card border-4 border-dark shadow-sm mt-5 mb-5" style="box-shadow: 6px 6px 0px #000 !important;">
    <div class="card-header bg-warning border-bottom border-4 border-dark fw-bold fs-4 text-dark py-3 d-flex align-items-center">
        <span class="me-2">📅</span> Patient Appointments
    </div>

    <div class="card-body p-0 table-responsive bg-white">
        <table class="table table-hover align-middle mb-0 text-center fw-semibold">
            <thead class="table-dark">
                <tr>
                    <th class="py-3 text-start ps-4 border-end border-dark">Patient Name</th>
                    <th class="border-end border-dark">Date & Time</th>
                    <th class="border-end border-dark">Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var docAppointments = ViewBag.DoctorAppointments as IEnumerable<El_Mooo_Clinic.DTOs.DtoAppointment.ReadDTO>;
                }

                @if (docAppointments != null && docAppointments.Any())
                {
                    foreach (var app in docAppointments.OrderByDescending(a => a.AppointmentDate))
                    {
                        <tr class="border-bottom border-2 border-dark">
                            <td class="text-start ps-4 fw-bold fs-5 text-primary border-end border-2 border-dark">
                                @app.PatientName
                            </td>
                            <td class="border-end border-2 border-dark">
                                <div class="fw-bold text-dark">@app.AppointmentDate.ToString("MMM dd, yyyy")</div>
                                <span class="badge bg-light text-dark border border-dark">
                                    @app.AppointmentDate.ToString("hh:mm tt")
                                </span>
                            </td>
                            <td class="border-end border-2 border-dark">
                                @if (app.Status == "Completed")
                                {
                                    <span class="badge bg-success border border-dark px-2 py-1">@app.Status</span>
                                }
                                else if (app.Status == "Cancelled")
                                {
                                    <span class="badge bg-danger border border-dark px-2 py-1">@app.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary border border-dark px-2 py-1">@app.Status</span>
                                }
                            </td>
                            <td>
                                <a href="/Appointment/Details/@app.ID" class="btn btn-sm btn-info btn-neo px-3 fw-bold">
                                    👁️ Details
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted fw-bold fs-5">
                            No appointments booked for this doctor yet. 📭
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>