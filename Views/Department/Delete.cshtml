@model El_Mooo_Clinic.DTOs.DtoDepartment.ReadDTO

@{
    ViewData["Title"] = "Delete Department";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow text-center">
                <div class="card-body p-5">
                    <div class="display-1 text-danger mb-3">⚠️</div>
                    <h3 class="fw-bold text-danger">Are you sure?</h3>
                    <p class="text-muted fs-5">
                        You are about to delete the <strong class="text-dark">@Model.Name</strong> department. <br />
                        This action cannot be undone!
                    </p>

                    <form action="/Department/Delete/@Model.ID" method="post" class="mt-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ID" />

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-danger px-4 fw-bold">Yes, Delete it!</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>