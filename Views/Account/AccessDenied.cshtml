@{
    ViewData["Title"] = "Access Denied";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">

    <div class="text-center bg-danger p-5 border border-5 border-dark" style="max-width: 600px; box-shadow: 15px 15px 0px #1a1a1a;">

        <h1 class="display-1 mb-3">⛔</h1>

        <h1 class="fw-bold text-white mb-3" style="text-shadow: 3px 3px 0px #1a1a1a; font-size: 3.5rem;">
            ACCESS DENIED!
        </h1>

        <div class="bg-dark text-white border border-3 border-dark p-3 mb-4 mx-auto" style="transform: rotate(-2deg);">
            <h4 class="fw-bold mb-0 text-warning">Error 403: Forbidden Territory</h4>
        </div>

        <p class="fs-5 fw-bold text-white mb-5">
            Oops! It looks like you don't have the necessary permissions to enter this room. Only authorized personnel are allowed here.
        </p>

        <a href="/Home/Index" class="btn btn-warning border px-3 fw-semibold">
            ⬅️ Back to Safety
        </a>

    </div>

</div>