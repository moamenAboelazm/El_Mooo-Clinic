@{
    ViewData["Title"] = "Contact Us";
}

<div class="container mt-5 mb-5">

    <h1 class="text-primary fw-bold display-4 mb-5 border-bottom border-4 border-dark pb-3" style="text-shadow: 2px 2px 0px #000;">
        📞 Get in Touch
    </h1>

    <div class="row g-5">
        <div class="col-md-5">
            <div class="bg-light border border-4 border-dark p-4 h-100" style="box-shadow: 8px 8px 0px #000 !important;">
                <h3 class="fw-bold mb-4">Reach Out Directly</h3>

                <div class="d-flex align-items-center mb-4">
                    <span class="bg-warning border border-2 border-dark rounded-circle p-3 me-3 fs-4">📍</span>
                    <div>
                        <h5 class="fw-bold mb-0">Clinic Location</h5>
                        <p class="mb-0 fw-semibold">El_Zahabia Street , Hurghada , RedSea</p>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <span class="bg-success text-white border border-2 border-dark rounded-circle p-3 me-3 fs-4">📱</span>
                    <div>
                        <h5 class="fw-bold mb-0">Phone Number</h5>
                        <p class="mb-0 fw-semibold">+20 155 417 9457</p>
                    </div>
                </div>

                <div class="d-flex align-items-center">
                    <span class="bg-primary text-white border border-2 border-dark rounded-circle p-3 me-3 fs-4">📧</span>
                    <div>
                        <h5 class="fw-bold mb-0">Email Address</h5>
                        <p class="mb-0 fw-semibold">moamenazm6@gmail.com</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <form class="bg-white border border-4 border-dark p-4 h-100" style="box-shadow: 8px 8px 0px #000 !important;">
                <h3 class="fw-bold mb-4">Send us a Message</h3>

                <div class="mb-3">
                    <label class="fw-bold mb-2">Your Name</label>
                    <input type="text" class="form-control border-3 border-dark p-3 fw-bold" placeholder="e.g. Patrik Moamen" required>
                </div>

                <div class="mb-3">
                    <label class="fw-bold mb-2">Email Address</label>
                    <input type="email" class="form-control border-3 border-dark p-3 fw-bold" placeholder="patrik@example.com" required>
                </div>

                <div class="mb-4">
                    <label class="fw-bold mb-2">Message</label>
                    <textarea class="form-control border-3 border-dark p-3 fw-bold" rows="4" placeholder="How can we help you today?" required></textarea>
                </div>

                <button type="submit" class="btn btn-light w-100 fw-bold fs-4 py-3 border border-3 border-dark text-primary">
                    🚀 Send Message
                </button>
            </form>
        </div>
    </div>

</div>