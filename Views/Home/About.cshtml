@{
    ViewData["Title"] = "About Us";
}

<div class="container mt-5 mb-5">

    <div class="bg-primary border border-4 border-dark p-5 mb-5 text-center" style="box-shadow: 6px 6px 0px #000 !important;">
        <h1 class="display-3 fw-bold text-white mb-3" style="text-shadow: 3px 3px 0px #000;">🏥 El-Mooo Clinic</h1>
        <h3 class="fw-bold text-dark bg-warning d-inline-block px-3 py-1 border border-3 border-dark">Healing with a smile, treating with tech!</h3>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100 bg-info border-4 border-dark p-4" style="box-shadow: 6px 6px 0px #000 !important;">
                <h2 class="fw-bold mb-3">👁️ Our Vision</h2>
                <p class="fs-5 fw-semibold mb-0">
                    To be the leading digital healthcare provider, where advanced technology meets compassionate patient care. We believe that booking a doctor should be as easy as ordering food.
                </p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 bg-warning border-4 border-dark p-4" style="box-shadow: 6px 6px 0px #000 !important;">
                <h2 class="fw-bold mb-3">🎯 Our Mission</h2>
                <p class="fs-5 fw-semibold mb-0">
                    Providing an ultra-fast, reliable, and beautifully designed clinic management system that empowers doctors to focus on healing, and patients to focus on recovery.
                </p>
            </div>
        </div>
    </div>

</div>