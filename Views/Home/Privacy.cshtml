@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5 mb-5">

    <div class="bg-dark text-white border border-4 border-dark p-4 mb-5" style="box-shadow: 8px 8px 0px #primary !important;">
        <h1 class="fw-bold display-5 mb-0">🛡️ Privacy Policy</h1>
    </div>

    <div class="bg-light border border-4 border-dark p-5" style="box-shadow: 6px 6px 0px #000 !important;">

        <h3 class="fw-bold text-primary mb-3">1. Data Collection</h3>
        <p class="fs-5 fw-semibold mb-5">
            At El-Mooo Clinic, we take your privacy seriously. We only collect the necessary medical and personal information required to provide you with the best healthcare services. Your medical records are kept strictly confidential.
        </p>

        <h3 class="fw-bold text-success mb-3">2. How We Use Your Information</h3>
        <p class="fs-5 fw-semibold mb-5">
            Your data is used exclusively for booking appointments, maintaining your medical history, and communicating with you regarding your health. We do NOT sell your data to third-party advertisers.
        </p>

        <h3 class="fw-bold text-warning mb-3">3. Data Security</h3>
        <p class="fs-5 fw-semibold mb-0">
            Our system is built using secure, modern technologies (.NET Core & EF Core). All sensitive data is encrypted, and access to patient files is restricted only to authorized medical personnel.
        </p>

    </div>
</div>