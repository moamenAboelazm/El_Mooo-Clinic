@model El_Mooo_Clinic.DTOs.DtoPatient.ReadDTO

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow text-center border-2">
                <div class="card-body p-5">
                    <div class="display-1 text-danger mb-3">⚠️</div>
                    <h3 class="fw-bold text-danger">Are you sure?</h3>
                    <p class="text-muted fs-5 mt-3">
                        You are about to delete the file of patient <strong class="text-dark">@Model.Name</strong>.<br />
                        This action cannot be undone!
                    </p>

                    <form action="/Patients/Delete/@Model.ID" method="post" class="mt-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ID" />

                        <div class="d-flex justify-content-center gap-3">
                            <a href="/Patient" class="btn btn-secondary px-4 fw-bold">Cancel</a>
                            <button type="submit" class="btn btn-danger px-4 fw-bold">Yes, Delete Patient</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>